{
  "name": "undetermini",
  "version": "0.2.0",
  "description": "Eval harness for non-deterministic (LLM) code — subjects, variants (provider × model × reasoning), weighted-assertion scoring, trial cache, SQLite runs, CLI + TUI.",
  "author": "Sraleik",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "eval": "tsx src/clients/cli/runner.ts",
    "eval:tui": "tsx src/clients/tui/runner.ts",
    "rescore": "tsx src/engine/rescore/sync-all.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup",
    "build:docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sraleik/undetermini.git"
  },
  "bugs": {
    "url": "https://github.com/sraleik/undetermini/issues"
  },
  "keywords": [
    "llm",
    "eval",
    "testing",
    "non-deterministic",
    "prompt-engineering"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "ai": "^6.0.116",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.3.1",
    "ink": "^5.2.1",
    "p-limit": "^5.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.20",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typedoc": "^0.26.11",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1"
  }
}
